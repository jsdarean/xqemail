# ==========================================
# 需求催办系统 - 环境变量配置示例
# 复制本文件为 .env 后填入真实值
# ==========================================

# 服务器配置
PORT=3000
HOST=0.0.0.0

# 访问认证（基础 HTTP 认证）
# 分发部署时强烈建议修改默认值
AUTH_USER=admin
AUTH_PASS=changeme

# 配置文件加密密钥（用于加密 email-config.json 中的密码）
# 建议使用 32 位以上随机字符串，部署后不要泄露
CONFIG_ENCRYPTION_KEY=your-32-char-encryption-key-here

# Session 密钥（用于加密用户登录 Session）
# 建议使用长随机字符串
SESSION_SECRET=your-long-random-session-secret-here

# MySQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=aicoding
DB_CHARSET=utf8mb4

# 本地 SMTP 中继服务器（与 Chrome 插件共用）
RELAY_SERVER=http://127.0.0.1:2525

# SMTP 发件配置
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password_or_app_key
IMAP_HOST=imap.example.com
IMAP_PORT=993

# 邮件签名与默认抄送
EMAIL_SIGNATURE=您的签名
EMAIL_DEFAULT_CC=
